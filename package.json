{
  "name": "church-live-stream-studio",
  "version": "1.0.0",
  "description": "Church Live Stream Studio - Professional streaming for churches",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.node.json && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "preview": "vite preview",
    "electron:dev": "wait-on http://localhost:5173 && electron ."
  },
  "dependencies": {
    "@fontsource/amiri": "^5.2.8",
    "@fontsource/cairo": "^5.2.7",
    "@fontsource/lalezar": "^5.2.7",
    "@fontsource/noto-kufi-arabic": "^5.2.9",
    "@fontsource/noto-sans-coptic": "^5.2.7",
    "@fontsource/reem-kufi": "^5.2.11",
    "@fontsource/tajawal": "^5.2.7",
    "adm-zip": "^0.5.16",
    "electron-store": "^8.1.0",
    "mammoth": "^1.12.0",
    "officeparser": "^4.1.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.church.livestream",
    "productName": "Church Live Stream Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/pdf-parse/**",
      "node_modules/mammoth/**",
      "node_modules/adm-zip/**",
      "node_modules/officeparser/**"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/"
      }
    ]
  }
}
