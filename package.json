{
  "name": "church-live-stream-studio",
  "version": "1.0.0",
  "description": "Church Live Stream Studio - Professional streaming for churches",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "wait-on http://localhost:5173 && electron ."
  },
  "dependencies": {
    "officeparser": "^4.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.church.livestream",
    "productName": "Church Live Stream Studio",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/"
      }
    ]
  }
}
